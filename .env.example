# Azure OpenAI (via Azure AI Foundry or standalone Azure OpenAI resource)
# Endpoint format: https://<resource-name>.openai.azure.com/
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21

# MSAL / Azure App Registration
MSAL_CLIENT_ID=
MSAL_TENANT_ID=common
MSAL_REDIRECT_URI=http://localhost

# Logging
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
